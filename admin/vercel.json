{
  "rewrites": [
    {
      "source": "/home",
      "destination": "https://tem-user-page.vercel.app/home"
    },
    {
      "source": "/login",
      "destination": "https://tem-user-page.vercel.app/login"
    },
    {
      "source": "/register",
      "destination": "https://tem-user-page.vercel.app/register"
    },
    {
      "source": "/select-store",
      "destination": "https://tem-user-page.vercel.app/select-store"
    },
    {
      "source": "/success",
      "destination": "https://tem-user-page.vercel.app/success"
    },
    {
      "source": "/history",
      "destination": "https://tem-user-page.vercel.app/history"
    },
    {
      "source": "/trace/:code",
      "destination": "https://tem-user-page.vercel.app/trace/:code"
    },
    {
      "source": "/scan/:code",
      "destination": "https://tem-user-page.vercel.app/scan/:code"
    },
    {
      "source": "/qrcode/:code",
      "destination": "https://tem-user-page.vercel.app/qrcode/:code"
    },
    {
      "source": "/temqr/:code",
      "destination": "https://tem-user-page.vercel.app/temqr/:code"
    },
    {
      "source": "/product-info",
      "destination": "https://tem-user-page.vercel.app/product-info"
    },
    {
      "source": "/((?!assets/|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
